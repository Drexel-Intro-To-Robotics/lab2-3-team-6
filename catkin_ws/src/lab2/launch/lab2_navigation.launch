<launch>
    <arg name="map_file" default="/workspaces/individual-lab-code-Andracle-1/GridMap.yaml" />
    <arg name="rviz_config" default="/workspaces/individual-lab-code-Andracle-1/GridMap.rviz" />

    <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_file)" />

    <node pkg="tf" type="static_transform_publisher" name="map_to_odom_broadcaster" args="0 0 0 0 0 0 map odom 100" />

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(arg rviz_config)" required="true" />

    <node pkg="lab2" type="navigate.py" name="navigate" output="screen" />

    <node pkg="lab2" type="travel.py" name="travel" output="screen" />
</launch>